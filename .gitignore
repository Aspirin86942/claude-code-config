# =============================================================================
# Claude Code Sync Configuration - .gitignore
# Purpose: Enable cross-device sync of core config while excluding cache/session data
# Target: C:\Users\chenzixuan\.claude
# =============================================================================

# -----------------------------------------------------------------------------
# ✅ SYNCED: Core Configuration Files (核心配置 - 这些文件会被同步)
# -----------------------------------------------------------------------------
# CLAUDE.md          - 用户核心指令
# settings.json      - 权限/环境配置
# config.json        - 基础配置
# skills/            - 自定义技能
# agents/            - Agent 定义
# ide/, plugins/, projects/ - 配置数据

# -----------------------------------------------------------------------------
# ❌ EXCLUDED: Git (Git 目录)
# -----------------------------------------------------------------------------
.git/

# -----------------------------------------------------------------------------
# ❌ EXCLUDED: Cache & Temporary Data (缓存数据)
# -----------------------------------------------------------------------------
cache/
paste-cache/
stats-cache.json

# -----------------------------------------------------------------------------
# ❌ EXCLUDED: Logs & Telemetry (日志与遥测数据)
# -----------------------------------------------------------------------------
debug/
telemetry/
statsig/

# -----------------------------------------------------------------------------
# ❌ EXCLUDED: Session History & State (会话状态数据)
# -----------------------------------------------------------------------------
history.jsonl
sessions/
shell-snapshots/
file-history/

# -----------------------------------------------------------------------------
# ❌ EXCLUDED: Backups & Downloads (备份与下载)
# -----------------------------------------------------------------------------
backups/
downloads/

# -----------------------------------------------------------------------------
# ❌ EXCLUDED: System Files (系统文件)
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# ❌ EXCLUDED: 其他
# -----------------------------------------------------------------------------
tasks/
todos/
projects/
plugins/
ide/